# Copy this file to .env and fill in real values.
# Vars prefixed VITE_ are PUBLIC — they ship to the browser. Never put a
# secret behind a VITE_ prefix.

# --- Public (client + server) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Server-only secrets (do NOT prefix with VITE_) ---
# Service-role key from Supabase project settings > API. Bypasses RLS —
# only ever read on the server (src/lib/supabaseAdmin.server.ts).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin panel login. Pick a real, unique password — there is no default
# fallback, so the app will refuse to start the admin auth flow without it.
ADMIN_USERNAME=choose-a-username
ADMIN_PASSWORD=choose-a-strong-password

# Random secret used to sign/encrypt the admin session cookie.
# Generate one with: openssl rand -hex 32
ADMIN_SESSION_SECRET=replace-with-a-random-64-char-hex-string
